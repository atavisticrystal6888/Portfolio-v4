# -----------------------------------------------------------------------------
# portfolio-v4 environment variables
# Copy to .env.local and fill what you need. All are optional — the app falls
# back gracefully when unset.
# -----------------------------------------------------------------------------

# GitHub integration (About page live stats, ISR).
# Token needs only `public_repo` + `read:user` scopes.
# Leave blank in dev — the page renders placeholder stats instead.
GITHUB_TOKEN=
GITHUB_USERNAME=

# Contact form (Resend). Without these, /api/contact returns 503.
RESEND_API_KEY=
CONTACT_EMAIL=

# Canonical site URL. Used for sitemap, RSS, OG images, and absolute links.
# In prod on Vercel, set this to https://your-domain.com.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Analytics (Vercel)
# -----------------------------------------------------------------------------
# @vercel/analytics auto-connects when deployed to Vercel — no key required.
# In local dev the component is a no-op.
